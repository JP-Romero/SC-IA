# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE: Configuración del proyecto Supabase
# Obtén estos valores desde: https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/api
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# GOOGLE MAPS: llave del navegador para Maps Embed API / Maps JavaScript API
# Restríngela por dominio en Google Cloud antes de publicarla en producción.
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# GOOGLE CLOUD HEALTHCARE API (FHIR R4)
# Required for storing medical data in FHIR standard
# Setup: https://cloud.google.com/healthcare-api/docs/how-tos/fhir
GCP_PROJECT_ID="YOUR_GCP_PROJECT_ID"
GCP_HEALTHCARE_LOCATION="us-central1"
GCP_HEALTHCARE_DATASET="YOUR_DATASET_NAME"
GCP_HEALTHCARE_FHIR_STORE="YOUR_FHIR_STORE_NAME"
GCP_SERVICE_ACCOUNT_EMAIL="YOUR_SERVICE_ACCOUNT@YOUR_PROJECT.iam.gserviceaccount.com"
GCP_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
